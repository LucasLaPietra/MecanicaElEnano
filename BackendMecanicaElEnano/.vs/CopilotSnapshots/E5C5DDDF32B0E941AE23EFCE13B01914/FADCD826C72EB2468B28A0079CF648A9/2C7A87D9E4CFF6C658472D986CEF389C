using AutoMapper;
using BackendMecanicaElEnano.Common;
using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Models;
using BackendMecanicaElEnano.UnitOfWork;
using Microsoft.EntityFrameworkCore;

namespace BackendMecanicaElEnano.Services
{
    /// <summary>
    /// Service layer containing business logic for Vehiculo operations
    /// </summary>
    public class VehiculoService : IVehiculoService
    {
        private readonly IUnitOfWork _unitOfWork;
        private readonly IMapper _mapper;
        private readonly ILogger<VehiculoService> _logger;

        public VehiculoService(IUnitOfWork unitOfWork, IMapper mapper, ILogger<VehiculoService> logger)
        {
            _unitOfWork = unitOfWork;
            _mapper = mapper;
            _logger = logger;
        }

        public async Task<Result<IList<VehiculoDto>>> GetAllAsync()
        {
            try
            {
                _logger.LogInformation("Retrieving all vehiculos");
                var vehiculos = await _unitOfWork.Vehiculos.FindAll()
                    .Include(v => v.Presupuestos)
                    .Include(v => v.Trabajos)
                    .Include(v => v.OrdenTrabajos)
                    .ToListAsync();
                var vehiculosDto = _mapper.Map<IList<VehiculoDto>>(vehiculos);

                _logger.LogInformation("Successfully retrieved {Count} vehiculos", vehiculosDto.Count);
                return Result.Success(vehiculosDto);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while retrieving all vehiculos");
                return Result.Failure<IList<VehiculoDto>>("Error al obtener los vehículos");
            }
        }

        public async Task<Result<VehiculoDto>> GetByIdAsync(Guid id)
        {
            try
            {
                _logger.LogInformation("Retrieving vehiculo with ID: {Id}", id);

                if (id == Guid.Empty)
                {
                    _logger.LogWarning("Invalid vehiculo ID provided: {Id}", id);
                    return Result.Failure<VehiculoDto>("El ID del vehículo no es válido");
                }

                var vehiculo = await _unitOfWork.Vehiculos
                    .FindByCondition(v => v.VehiculoId == id)
                    .Include(v => v.Presupuestos)
                    .Include(v => v.Trabajos)
                    .Include(v => v.OrdenTrabajos)
                    .FirstOrDefaultAsync();

                if (vehiculo == null)
                {
                    _logger.LogWarning("Vehiculo with ID {Id} not found", id);
                    return Result.Failure<VehiculoDto>($"No se encontró el vehículo con ID {id}");
                }

                var vehiculoDto = _mapper.Map<VehiculoDto>(vehiculo);
                _logger.LogInformation("Successfully retrieved vehiculo with ID: {Id}", id);

                return Result.Success(vehiculoDto);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while retrieving vehiculo with ID: {Id}", id);
                return Result.Failure<VehiculoDto>("Error al obtener el vehículo");
            }
        }

        public async Task<Result<VehiculoDto>> GetByPatenteAsync(string patente)
        {
            try
            {
                _logger.LogInformation("Retrieving vehiculo with patente: {Patente}", patente);

                if (string.IsNullOrWhiteSpace(patente))
                {
                    _logger.LogWarning("Invalid patente provided");
                    return Result.Failure<VehiculoDto>("La patente no es válida");
                }

                var vehiculo = await _unitOfWork.Vehiculos
                    .FindByCondition(v => v.Patente == patente)
                    .Include(v => v.Presupuestos)
                    .Include(v => v.Trabajos)
                    .Include(v => v.OrdenTrabajos)
                    .FirstOrDefaultAsync();

                if (vehiculo == null)
                {
                    _logger.LogWarning("Vehiculo with patente {Patente} not found", patente);
                    return Result.Failure<VehiculoDto>($"No se encontró el vehículo con patente {patente}");
                }

                var vehiculoDto = _mapper.Map<VehiculoDto>(vehiculo);
                _logger.LogInformation("Successfully retrieved vehiculo with patente: {Patente}", patente);

                return Result.Success(vehiculoDto);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while retrieving vehiculo with patente: {Patente}", patente);
                return Result.Failure<VehiculoDto>("Error al obtener el vehículo");
            }
        }

        public async Task<Result<VehiculoDto>> CreateAsync(CreateVehiculoDto dto)
        {
            try
            {
                _logger.LogInformation("Creating vehiculo with patente: {Patente}", dto.Patente);

                // Validate input
                if (string.IsNullOrWhiteSpace(dto.Patente))
                {
                    _logger.LogWarning("Patente is required");
                    return Result.Failure<VehiculoDto>("La patente es requerida");
                }

                if (dto.Patente.Length < 6 || dto.Patente.Length > 7)
                {
                    _logger.LogWarning("Invalid patente length: {Length}", dto.Patente.Length);
                    return Result.Failure<VehiculoDto>("La patente debe tener 6 o 7 caracteres");
                }

                if (string.IsNullOrWhiteSpace(dto.Modelo))
                {
                    return Result.Failure<VehiculoDto>("El modelo es requerido");
                }

                if (string.IsNullOrWhiteSpace(dto.Cliente))
                {
                    return Result.Failure<VehiculoDto>("El nombre del cliente es requerido");
                }

                if (string.IsNullOrWhiteSpace(dto.Telefono))
                {
                    return Result.Failure<VehiculoDto>("El teléfono es requerido");
                }

                // Check if patente already exists
                var exists = await _unitOfWork.Vehiculos
                    .FindByCondition(v => v.Patente == dto.Patente)
                    .AnyAsync();

                if (exists)
                {
                    _logger.LogWarning("Vehiculo with patente {Patente} already exists", dto.Patente);
                    return Result.Failure<VehiculoDto>("Ya existe un vehículo con esa patente");
                }

                // Set default values for nullable fields
                dto.Cuit ??= string.Empty;
                dto.Mail ??= string.Empty;
                dto.NumeroChasis ??= string.Empty;

                var vehiculo = _mapper.Map<Vehiculo>(dto);
                vehiculo.VehiculoId = Guid.NewGuid();

                _unitOfWork.Vehiculos.Create(vehiculo);
                await _unitOfWork.CommitAsync();

                var vehiculoDto = _mapper.Map<VehiculoDto>(vehiculo);
                _logger.LogInformation("Successfully created vehiculo with ID: {Id}", vehiculo.VehiculoId);

                return Result.Success(vehiculoDto);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while creating vehiculo");
                await _unitOfWork.RollbackAsync();
                return Result.Failure<VehiculoDto>("Error al crear el vehículo");
            }
        }

        public async Task<Result<VehiculoDto>> UpdateAsync(VehiculoDto dto)
        {
            try
            {
                _logger.LogInformation("Updating vehiculo with ID: {Id}", dto.VehiculoId);

                // Validate input
                if (dto.VehiculoId == Guid.Empty)
                {
                    _logger.LogWarning("Invalid vehiculo ID provided");
                    return Result.Failure<VehiculoDto>("El ID del vehículo no es válido");
                }

                if (string.IsNullOrWhiteSpace(dto.Patente))
                {
                    return Result.Failure<VehiculoDto>("La patente es requerida");
                }

                if (dto.Patente.Length < 6 || dto.Patente.Length > 7)
                {
                    return Result.Failure<VehiculoDto>("La patente debe tener 6 o 7 caracteres");
                }

                var vehiculo = await _unitOfWork.Vehiculos
                    .FindByCondition(v => v.VehiculoId == dto.VehiculoId)
                    .FirstOrDefaultAsync();

                if (vehiculo == null)
                {
                    _logger.LogWarning("Vehiculo with ID {Id} not found for update", dto.VehiculoId);
                    return Result.Failure<VehiculoDto>($"No se encontró el vehículo con ID {dto.VehiculoId}");
                }

                // Check if patente is being changed and if new patente already exists
                if (vehiculo.Patente != dto.Patente)
                {
                    var patenteExists = await _unitOfWork.Vehiculos
                        .FindByCondition(v => v.Patente == dto.Patente && v.VehiculoId != dto.VehiculoId)
                        .AnyAsync();

                    if (patenteExists)
                    {
                        _logger.LogWarning("Patente {Patente} already exists for another vehicle", dto.Patente);
                        return Result.Failure<VehiculoDto>("Ya existe otro vehículo con esa patente");
                    }
                }

                // Update properties
                vehiculo.Patente = dto.Patente;
                vehiculo.Modelo = dto.Modelo;
                vehiculo.NumeroChasis = dto.NumeroChasis;
                vehiculo.Cliente = dto.Cliente;
                vehiculo.Telefono = dto.Telefono;
                vehiculo.Direccion = dto.Direccion;
                vehiculo.Mail = dto.Mail;
                vehiculo.Cuit = dto.Cuit;

                _unitOfWork.Vehiculos.Update(vehiculo);
                await _unitOfWork.CommitAsync();

                var updatedDto = _mapper.Map<VehiculoDto>(vehiculo);
                _logger.LogInformation("Successfully updated vehiculo with ID: {Id}", vehiculo.VehiculoId);

                return Result.Success(updatedDto);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while updating vehiculo with ID: {Id}", dto.VehiculoId);
                await _unitOfWork.RollbackAsync();
                return Result.Failure<VehiculoDto>("Error al actualizar el vehículo");
            }
        }

        public async Task<Result> DeleteAsync(Guid id)
        {
            try
            {
                _logger.LogInformation("Deleting vehiculo with ID: {Id}", id);

                if (id == Guid.Empty)
                {
                    _logger.LogWarning("Invalid vehiculo ID provided: {Id}", id);
                    return Result.Failure("El ID del vehículo no es válido");
                }

                var vehiculo = await _unitOfWork.Vehiculos
                    .FindByCondition(v => v.VehiculoId == id)
                    .FirstOrDefaultAsync();

                if (vehiculo == null)
                {
                    _logger.LogWarning("Vehiculo with ID {Id} not found for deletion", id);
                    return Result.Failure($"No se encontró el vehículo con ID {id}");
                }

                // Check if vehiculo has related presupuestos or trabajos
                var hasPresupuestos = await _unitOfWork.Presupuestos
                    .FindByCondition(p => p.VehiculoId == id)
                    .AnyAsync();

                if (hasPresupuestos)
                {
                    _logger.LogWarning("Cannot delete vehiculo {Id} - has related presupuestos", id);
                    return Result.Failure("No se puede eliminar el vehículo porque tiene presupuestos asociados");
                }

                _unitOfWork.Vehiculos.Delete(vehiculo);
                await _unitOfWork.CommitAsync();

                _logger.LogInformation("Successfully deleted vehiculo with ID: {Id}", id);
                return Result.Success();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred while deleting vehiculo with ID: {Id}", id);
                await _unitOfWork.RollbackAsync();
                return Result.Failure("Error al eliminar el vehículo");
            }
        }
    }
}
