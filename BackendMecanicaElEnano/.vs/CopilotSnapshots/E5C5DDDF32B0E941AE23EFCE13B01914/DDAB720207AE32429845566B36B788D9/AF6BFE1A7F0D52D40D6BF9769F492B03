using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Services;
using Microsoft.AspNetCore.Mvc;

namespace BackendMecanicaElEnano.Controllers
{
    /// <summary>
    /// Controller for managing Vehiculos (Vehicles)
    /// Uses Service Layer following Clean Architecture principles
    /// </summary>
    [ApiController]
    [Route("api/vehiculos")]
    public class VehiculoController : ControllerBase
    {
        private readonly IVehiculoService _vehiculoService;
        private readonly ILogger<VehiculoController> _logger;

        public VehiculoController(IVehiculoService vehiculoService, ILogger<VehiculoController> logger)
        {
            _vehiculoService = vehiculoService;
            _logger = logger;
        }

        /// <summary>
        /// Creates a new vehiculo
        /// </summary>
        [HttpPost]
        [ProducesResponseType(StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<VehiculoDto>> Create([FromBody] CreateVehiculoDto vehiculo)
        {
            _logger.LogInformation("POST api/vehiculos - Creating vehiculo");

            var result = await _vehiculoService.CreateAsync(vehiculo);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to create vehiculo: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully created vehiculo with ID: {Id}", result.Value.VehiculoId);
            return CreatedAtAction(nameof(GetById), new { id = result.Value.VehiculoId }, result.Value);
        }

        /// <summary>
        /// Gets all vehiculos
        /// </summary>
        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<List<VehiculoDto>>> GetAll()
        {
            _logger.LogInformation("GET api/vehiculos - Retrieving all vehiculos");

            var result = await _vehiculoService.GetAllAsync();

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve vehiculos: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved {Count} vehiculos", result.Value.Count);
            return Ok(result.Value);
        }

        /// <summary>
        /// Gets a specific vehiculo by ID
        /// </summary>
        [HttpGet("{id}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<VehiculoDto>> GetById(Guid id)
        {
            _logger.LogInformation("GET api/vehiculos/{Id} - Retrieving vehiculo", id);

            var result = await _vehiculoService.GetByIdAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve vehiculo {Id}: {Error}", id, result.Error);
                return NotFound(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved vehiculo with ID: {Id}", id);
            return Ok(result.Value);
        }

        /// <summary>
        /// Gets a vehiculo by patente
        /// </summary>
        [HttpGet("patente/{patente}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<VehiculoDto>> GetByPatente(string patente)
        {
            _logger.LogInformation("GET api/vehiculos/patente/{Patente}", patente);

            var result = await _vehiculoService.GetByPatenteAsync(patente);

            if (result.IsFailure)
            {
                return NotFound(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        /// <summary>
        /// Updates an existing vehiculo
        /// </summary>
        [HttpPut]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<VehiculoDto>> Update([FromBody] VehiculoDto vehiculo)
        {
            _logger.LogInformation("PUT api/vehiculos - Updating vehiculo {Id}", vehiculo.VehiculoId);

            var result = await _vehiculoService.UpdateAsync(vehiculo);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to update vehiculo {Id}: {Error}", vehiculo.VehiculoId, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully updated vehiculo with ID: {Id}", vehiculo.VehiculoId);
            return Ok(result.Value);
        }

        /// <summary>
        /// Deletes a vehiculo by ID
        /// </summary>
        [HttpDelete("{id}")]
        [ProducesResponseType(StatusCodes.Status204NoContent)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult> Delete(Guid id)
        {
            _logger.LogInformation("DELETE api/vehiculos/{Id} - Deleting vehiculo", id);

            var result = await _vehiculoService.DeleteAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to delete vehiculo {Id}: {Error}", id, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully deleted vehiculo with ID: {Id}", id);
            return NoContent();
        }
    }
}

