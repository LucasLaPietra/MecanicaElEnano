using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Services;
using Microsoft.AspNetCore.Mvc;

namespace BackendMecanicaElEnano.Controllers
{
    /// <summary>
    /// Controller for managing Presupuestos (Quotes/Estimates)
    /// Now uses Service Layer following Clean Architecture principles
    /// </summary>
    [ApiController]
    [Route("api/presupuestos")]
    public class PresupuestoController : ControllerBase
    {
        private readonly IPresupuestoService _presupuestoService;
        private readonly ILogger<PresupuestoController> _logger;

        public PresupuestoController(IPresupuestoService presupuestoService, ILogger<PresupuestoController> logger)
        {
            _presupuestoService = presupuestoService;
            _logger = logger;
        }

        /// <summary>
        /// Creates a new presupuesto for a specific vehicle
        /// </summary>
        [HttpPost]
        [ProducesResponseType(StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<PresupuestoDto>> Create([FromBody] Guid vehiculoId)
        {
            _logger.LogInformation("POST api/presupuestos - Creating presupuesto for vehicle {VehiculoId}", vehiculoId);

            var result = await _presupuestoService.CreateAsync(vehiculoId);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to create presupuesto: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully created presupuesto with ID: {Id}", result.Value.PresupuestoId);
            return CreatedAtAction(nameof(GetById), new { id = result.Value.PresupuestoId }, result.Value);
        }

        /// <summary>
        /// Gets all presupuestos
        /// </summary>
        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<List<PresupuestoDto>>> GetAll()
        {
            _logger.LogInformation("GET api/presupuestos - Retrieving all presupuestos");

            var result = await _presupuestoService.GetAllAsync();

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve presupuestos: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved {Count} presupuestos", result.Value.Count);
            return Ok(result.Value);
        }

        /// <summary>
        /// Gets a specific presupuesto by ID
        /// </summary>
        [HttpGet("{id}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<PresupuestoDto>> GetById(Guid id)
        {
            _logger.LogInformation("GET api/presupuestos/{Id} - Retrieving presupuesto", id);

            var result = await _presupuestoService.GetByIdAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve presupuesto {Id}: {Error}", id, result.Error);
                return NotFound(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved presupuesto with ID: {Id}", id);
            return Ok(result.Value);
        }

        /// <summary>
        /// Updates an existing presupuesto
        /// </summary>
        [HttpPut]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<PresupuestoDto>> Update([FromBody] UpdatePresupuestoDto presupuesto)
        {
            _logger.LogInformation("PUT api/presupuestos - Updating presupuesto {Id}", presupuesto.PresupuestoId);

            var result = await _presupuestoService.UpdateAsync(presupuesto);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to update presupuesto {Id}: {Error}", presupuesto.PresupuestoId, result.Error);

                // Return 404 if not found, 400 for other validation errors
                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully updated presupuesto with ID: {Id}", presupuesto.PresupuestoId);
            return Ok(result.Value);
        }

        /// <summary>
        /// Deletes a presupuesto by ID
        /// </summary>
        [HttpDelete("{id}")]
        [ProducesResponseType(StatusCodes.Status204NoContent)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult> Delete(Guid id)
        {
            _logger.LogInformation("DELETE api/presupuestos/{Id} - Deleting presupuesto", id);

            var result = await _presupuestoService.DeleteAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to delete presupuesto {Id}: {Error}", id, result.Error);

                // Return 404 if not found, 400 for other validation errors
                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully deleted presupuesto with ID: {Id}", id);
            return NoContent();
        }
    }
}
