using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Services;
using Microsoft.AspNetCore.Mvc;

namespace BackendMecanicaElEnano.Controllers
{
    [ApiController]
    [Route("api/trabajos")]
    public class TrabajoController : ControllerBase
    {
        private readonly ITrabajoService _trabajoService;
        private readonly ILogger<TrabajoController> _logger;

        public TrabajoController(ITrabajoService trabajoService, ILogger<TrabajoController> logger)
        {
            _trabajoService = trabajoService;
            _logger = logger;
        }

        [HttpPost]
        [ProducesResponseType(StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<TrabajoDto>> Create([FromBody] Guid vehiculoId)
        {
            _logger.LogInformation("POST api/trabajos - Creating trabajo");

            var result = await _trabajoService.CreateAsync(vehiculoId);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to create trabajo: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully created trabajo with ID: {Id}", result.Value.TrabajoId);
            return CreatedAtAction(nameof(GetById), new { id = result.Value.TrabajoId }, result.Value);
        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<List<TrabajoDto>>> GetAll()
        {
            _logger.LogInformation("GET api/trabajos - Retrieving all trabajos");

            var result = await _trabajoService.GetAllAsync();

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve trabajos: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved {Count} trabajos", result.Value.Count);
            return Ok(result.Value);
        }

        [HttpGet("{id}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<TrabajoDto>> GetById(Guid id)
        {
            _logger.LogInformation("GET api/trabajos/{Id}", id);

            var result = await _trabajoService.GetByIdAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve trabajo {Id}: {Error}", id, result.Error);
                return NotFound(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpPut]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<TrabajoDto>> Update([FromBody] UpdateTrabajoDto trabajo)
        {
            _logger.LogInformation("PUT api/trabajos - Updating trabajo {Id}", trabajo.TrabajoId);

            var result = await _trabajoService.UpdateAsync(trabajo);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to update trabajo {Id}: {Error}", trabajo.TrabajoId, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpDelete("{id}")]
        [ProducesResponseType(StatusCodes.Status204NoContent)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult> Delete(Guid id)
        {
            _logger.LogInformation("DELETE api/trabajos/{Id}", id);

            var result = await _trabajoService.DeleteAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to delete trabajo {Id}: {Error}", id, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return NoContent();
        }
    }
}
