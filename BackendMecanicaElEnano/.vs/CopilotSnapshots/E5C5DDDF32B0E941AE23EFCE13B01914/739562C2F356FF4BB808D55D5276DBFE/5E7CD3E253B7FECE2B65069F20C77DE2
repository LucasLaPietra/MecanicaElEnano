using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Services;
using Microsoft.AspNetCore.Mvc;

namespace BackendMecanicaElEnano.Controllers
{
    [ApiController]
    [Route("api/turnos")]
    public class TurnoController : ControllerBase
    {
        private readonly ITurnoService _turnoService;
        private readonly ILogger<TurnoController> _logger;

        public TurnoController(ITurnoService turnoService, ILogger<TurnoController> logger)
        {
            _turnoService = turnoService;
            _logger = logger;
        }

        [HttpPost]
        [ProducesResponseType(StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<TurnoDto>> Create([FromBody] CreateTurnoDto turno)
        {
            _logger.LogInformation("POST api/turnos - Creating turno");

            var result = await _turnoService.CreateAsync(turno);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to create turno: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully created turno with ID: {Id}", result.Value.TurnoId);
            return CreatedAtAction(nameof(GetById), new { id = result.Value.TurnoId }, result.Value);
        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<List<TurnoDto>>> GetAll()
        {
            _logger.LogInformation("GET api/turnos - Retrieving all turnos");

            var result = await _turnoService.GetAllAsync();

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve turnos: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved {Count} turnos", result.Value.Count);
            return Ok(result.Value);
        }

        [HttpGet("{id}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<TurnoDto>> GetById(Guid id)
        {
            _logger.LogInformation("GET api/turnos/{Id}", id);

            var result = await _turnoService.GetByIdAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve turno {Id}: {Error}", id, result.Error);
                return NotFound(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpPut]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<TurnoDto>> Update([FromBody] TurnoDto turno)
        {
            _logger.LogInformation("PUT api/turnos - Updating turno {Id}", turno.TurnoId);

            var result = await _turnoService.UpdateAsync(turno);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to update turno {Id}: {Error}", turno.TurnoId, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpDelete("{id}")]
        [ProducesResponseType(StatusCodes.Status204NoContent)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult> Delete(Guid id)
        {
            _logger.LogInformation("DELETE api/turnos/{Id}", id);

            var result = await _turnoService.DeleteAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to delete turno {Id}: {Error}", id, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return NoContent();
        }
    }
}
