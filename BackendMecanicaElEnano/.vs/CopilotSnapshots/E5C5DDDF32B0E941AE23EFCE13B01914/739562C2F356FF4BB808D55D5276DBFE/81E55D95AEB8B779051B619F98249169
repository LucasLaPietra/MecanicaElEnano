using BackendMecanicaElEnano.Dto;
using BackendMecanicaElEnano.Services;
using Microsoft.AspNetCore.Mvc;

namespace BackendMecanicaElEnano.Controllers
{
    [ApiController]
    [Route("api/ordenTrabajos")]
    public class OrdenTrabajoController : ControllerBase
    {
        private readonly IOrdenTrabajoService _ordenTrabajoService;
        private readonly ILogger<OrdenTrabajoController> _logger;

        public OrdenTrabajoController(IOrdenTrabajoService ordenTrabajoService, ILogger<OrdenTrabajoController> logger)
        {
            _ordenTrabajoService = ordenTrabajoService;
            _logger = logger;
        }

        [HttpPost]
        [ProducesResponseType(StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<OrdenTrabajoDto>> Create([FromBody] Guid vehiculoId)
        {
            _logger.LogInformation("POST api/ordenTrabajos - Creating orden de trabajo");

            var result = await _ordenTrabajoService.CreateAsync(vehiculoId);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to create orden de trabajo: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully created orden de trabajo with ID: {Id}", result.Value.OrdenTrabajoId);
            return CreatedAtAction(nameof(GetById), new { id = result.Value.OrdenTrabajoId }, result.Value);
        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<ActionResult<List<OrdenTrabajoDto>>> GetAll()
        {
            _logger.LogInformation("GET api/ordenTrabajos - Retrieving all ordenes de trabajo");

            var result = await _ordenTrabajoService.GetAllAsync();

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve ordenes de trabajo: {Error}", result.Error);
                return BadRequest(new { error = result.Error });
            }

            _logger.LogInformation("Successfully retrieved {Count} ordenes de trabajo", result.Value.Count);
            return Ok(result.Value);
        }

        [HttpGet("{id}")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<OrdenTrabajoDto>> GetById(Guid id)
        {
            _logger.LogInformation("GET api/ordenTrabajos/{Id}", id);

            var result = await _ordenTrabajoService.GetByIdAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to retrieve orden de trabajo {Id}: {Error}", id, result.Error);
                return NotFound(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpPut]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult<OrdenTrabajoDto>> Update([FromBody] UpdateOrdenTrabajoDto ordenTrabajo)
        {
            _logger.LogInformation("PUT api/ordenTrabajos - Updating orden de trabajo {Id}", ordenTrabajo.OrdenTrabajoId);

            var result = await _ordenTrabajoService.UpdateAsync(ordenTrabajo);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to update orden de trabajo {Id}: {Error}", ordenTrabajo.OrdenTrabajoId, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return Ok(result.Value);
        }

        [HttpDelete("{id}")]
        [ProducesResponseType(StatusCodes.Status204NoContent)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<ActionResult> Delete(Guid id)
        {
            _logger.LogInformation("DELETE api/ordenTrabajos/{Id}", id);

            var result = await _ordenTrabajoService.DeleteAsync(id);

            if (result.IsFailure)
            {
                _logger.LogWarning("Failed to delete orden de trabajo {Id}: {Error}", id, result.Error);

                if (result.Error.Contains("no se encontró", StringComparison.OrdinalIgnoreCase))
                {
                    return NotFound(new { error = result.Error });
                }

                return BadRequest(new { error = result.Error });
            }

            return NoContent();
        }
    }
}
